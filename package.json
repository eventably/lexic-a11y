{
  "name": "@eventably/lexic-a11y",
  "version": "1.0.0",
  "description": "A fully featured, accessible, and internationalized rich text editor built with React and Lexical",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "vite",
    "build": "rollup -c",
    "build:analyze": "ANALYZE=true rollup -c",
    "build:demo": "vite build",
    "preview:demo": "vite preview",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint .",
    "lint:strict": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "lint:css": "stylelint 'src/**/*.css'",
    "lint:css:strict": "stylelint 'src/**/*.css' --max-warnings=0",
    "lint:css:fix": "stylelint 'src/**/*.css' --fix",
    "lint:md": "markdownlint-cli2 '**/*.md' '#node_modules' '#dist' '#build' '#coverage'",
    "lint:md:fix": "markdownlint-cli2 --fix '**/*.md' '#node_modules' '#dist' '#build' '#coverage'",
    "dupes": "jscpd . --config .jscpd.json",
    "dupes:ci": "jscpd . --config .jscpd.json --threshold 5",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "links": "lychee --no-progress --max-retries 0 --timeout 10 --exclude-path node_modules --exclude-path dist --exclude-path build --exclude-path coverage '**/*.md'",
    "size": "size-limit",
    "security:audit": "npm audit --production --audit-level=high",
    "security:osv": "osv-scanner --lockfile=package-lock.json",
    "security:semgrep": "semgrep --config=p/javascript --config=p/react --config=p/owasp-top-ten --error --metrics=off",
    "security:secrets": "trufflehog git file://. --only-verified --fail",
    "security": "npm-run-all -p security:audit security:osv security:semgrep security:secrets",
    "license:check": "license-checker-rseidelsohn --production --onlyAllow 'MIT;ISC;Apache-2.0;BSD-2-Clause;BSD-3-Clause;0BSD;CC0-1.0;Unlicense;Python-2.0;WTFPL;BlueOak-1.0.0' --excludePrivatePackages --summary",
    "license:report": "license-checker-rseidelsohn --production --csv --out reports/licenses.csv",
    "check": "npm-run-all -p lint lint:css lint:md format:check",
    "check:all": "npm-run-all -s check test build dupes size license:check security:audit security:secrets",
    "ci": "npm run check:all",
    "prepare": "husky",
    "example": "parcel serve examples/index.html --open",
    "codesandbox": "parcel serve sandbox.html",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed"
  },
  "keywords": [
    "react",
    "lexical",
    "editor",
    "rich-text",
    "a11y",
    "accessibility",
    "i18n"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "peerDependencies": {
    "react": "^16.8.0 || ^17.0.0 || ^18.0.0",
    "react-dom": "^16.8.0 || ^17.0.0 || ^18.0.0"
  },
  "dependencies": {
    "@lexical/html": "^0.12.0",
    "@lexical/link": "^0.12.0",
    "@lexical/list": "^0.12.0",
    "@lexical/markdown": "^0.12.0",
    "@lexical/react": "^0.12.0",
    "@lexical/rich-text": "^0.12.0",
    "@lexical/selection": "^0.12.6",
    "@lexical/table": "^0.12.0",
    "ajv": "^8.18.0",
    "i18next": "^23.0.0",
    "lexical": "^0.12.0",
    "react": "^16.8.0 || ^17.0.0 || ^18.0.0",
    "react-dom": "^16.8.0 || ^17.0.0 || ^18.0.0",
    "react-i18next": "^13.0.0"
  },
  "devDependencies": {
    "@afixt/a11y-assert": "2.1.3",
    "@axe-core/playwright": "4.11.3",
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.22.0",
    "@commitlint/cli": "19.8.1",
    "@commitlint/config-conventional": "19.8.1",
    "@double-great/stylelint-a11y": "3.4.10",
    "@eslint/js": "9.39.4",
    "@playwright/test": "1.60.0",
    "@rollup/plugin-babel": "^6.0.0",
    "@rollup/plugin-commonjs": "^25.0.0",
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@size-limit/preset-small-lib": "11.2.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^14.0.0",
    "@vitejs/plugin-react": "^5.2.0",
    "babel-jest": "^29.0.0",
    "eslint": "9.39.4",
    "eslint-config-prettier": "9.1.2",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-jsdoc": "51.4.1",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-n": "17.24.0",
    "eslint-plugin-no-secrets": "2.3.3",
    "eslint-plugin-promise": "7.2.1",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-security": "3.0.1",
    "eslint-plugin-sonarjs": "3.0.7",
    "eslint-plugin-unicorn": "60.0.0",
    "globals": "15.15.0",
    "husky": "^9.1.7",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^29.0.0",
    "jscpd": "^4.0.9",
    "license-checker-rseidelsohn": "4.4.2",
    "lint-staged": "^16.4.0",
    "markdownlint-cli2": "0.18.1",
    "npm-run-all": "4.1.5",
    "parcel": "^2.14.4",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "4.3.0",
    "rollup": "^2.80.0",
    "rollup-plugin-peer-deps-external": "^2.2.0",
    "rollup-plugin-postcss": "^4.0.0",
    "rollup-plugin-terser": "^7.0.0",
    "rollup-plugin-visualizer": "5.14.0",
    "size-limit": "11.2.0",
    "stylelint": "^17.8.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-declaration-strict-value": "1.11.1",
    "ts-api-utils": "2.5.0",
    "typescript": "5.9.3",
    "vite": "^7.3.2"
  },
  "size-limit": [
    {
      "name": "ESM bundle",
      "path": "dist/index.esm.js",
      "limit": "100 KB"
    },
    {
      "name": "CJS bundle",
      "path": "dist/index.js",
      "limit": "100 KB"
    }
  ],
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}

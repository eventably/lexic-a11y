{
  "name": "@eventably/lexic-a11y",
  "version": "1.0.0",
  "description": "A fully featured, accessible, and internationalized rich text editor built with React and Lexical",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "vite",
    "build": "rollup -c",
    "build:demo": "vite build",
    "preview:demo": "vite preview",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint 'src/**/*.{js,jsx}'",
    "lint:fix": "eslint 'src/**/*.{js,jsx}' --fix",
    "lint:css": "stylelint 'src/**/*.css'",
    "lint:md": "markdownlint '**/*.md' --ignore node_modules",
    "lint:cpd": "jscpd . --config .jscpd.json",
    "lint:cpd:ci": "jscpd . --config .jscpd.json --threshold 5",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "security:audit": "npm audit",
    "security:check": "npm audit --audit-level=high",
    "prepare": "husky",
    "example": "parcel serve examples/index.html --open",
    "codesandbox": "parcel serve sandbox.html"
  },
  "keywords": [
    "react",
    "lexical",
    "editor",
    "rich-text",
    "a11y",
    "accessibility",
    "i18n"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "react": "^16.8.0 || ^17.0.0 || ^18.0.0",
    "react-dom": "^16.8.0 || ^17.0.0 || ^18.0.0"
  },
  "dependencies": {
    "@lexical/html": "^0.12.0",
    "@lexical/link": "^0.12.0",
    "@lexical/list": "^0.12.0",
    "@lexical/react": "^0.12.0",
    "@lexical/rich-text": "^0.12.0",
    "@lexical/selection": "^0.12.6",
    "@lexical/table": "^0.12.0",
    "ajv": "^8.18.0",
    "i18next": "^23.0.0",
    "lexical": "^0.12.0",
    "react": "^16.8.0 || ^17.0.0 || ^18.0.0",
    "react-dom": "^16.8.0 || ^17.0.0 || ^18.0.0",
    "react-i18next": "^13.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.22.0",
    "@rollup/plugin-babel": "^6.0.0",
    "@rollup/plugin-commonjs": "^25.0.0",
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^14.0.0",
    "@vitejs/plugin-react": "^5.2.0",
    "babel-jest": "^29.0.0",
    "eslint": "^8.40.0",
    "eslint-plugin-jsx-a11y": "^6.7.0",
    "eslint-plugin-react": "^7.30.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "husky": "^9.1.7",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^29.0.0",
    "jscpd": "^4.0.9",
    "lint-staged": "^16.4.0",
    "markdownlint-cli": "^0.47.0",
    "parcel": "^2.14.4",
    "prettier": "^3.8.3",
    "rollup": "^2.80.0",
    "rollup-plugin-peer-deps-external": "^2.2.0",
    "rollup-plugin-postcss": "^4.0.0",
    "rollup-plugin-terser": "^7.0.0",
    "stylelint": "^17.8.0",
    "stylelint-config-standard": "^40.0.0",
    "vite": "^7.3.2"
  },
  "lint-staged": {
    "src/**/*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.css": [
      "stylelint --fix",
      "prettier --write"
    ],
    "*.md": [
      "markdownlint",
      "prettier --write"
    ],
    "*.{json,yml,yaml}": [
      "prettier --write"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}

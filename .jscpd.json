{
  "threshold": 5,
  "minTokens": 50,
  "minLines": 5,
  "maxLines": 1000,
  "maxSize": "100kb",
  "reporters": ["console", "html"],
  "output": "./reports/jscpd",
  "format": ["javascript", "jsx", "css", "scss", "markdown"],
  "ignore": [
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**",
    "**/coverage/**",
    "**/sandbox/**",
    "**/examples/**",
    "App.js",
    "**/*.test.{js,jsx}",
    "**/*.spec.{js,jsx}",
    "**/__fixtures__/**",
    "**/__snapshots__/**",
    "**/generated/**",
    "**/*.generated.*",
    "**/*.min.*"
  ],
  "absolute": true,
  "gitignore": true,
  "silent": false,
  "exitCode": 1
}
